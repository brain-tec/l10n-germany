<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="datev_export.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <block id="datev_export" position="inside">
                <setting
                    name="datev_account_code_length"
                    string="DATEV account code length"
                    company_dependent="1"
                    help="The length of an account code in DATEV"
                >
                    <field name="datev_account_code_length" />
                </setting>
                <setting
                    name="datev_partner_numbering"
                    string="DATEV Partner numbering"
                    company_dependent="1"
                >
                    <field name="datev_partner_numbering" required="True" />
                    <div invisible="datev_partner_numbering != 'sequence'">
                        <label for="datev_customer_sequence_id" class="w-100" />
                        <field
                            name="datev_customer_sequence_id"
                            required="datev_partner_numbering == 'sequence'"
                        />
                        <label for="datev_supplier_sequence_id" class="w-100" />
                        <field
                            name="datev_supplier_sequence_id"
                            required="datev_partner_numbering == 'sequence'"
                        />
                    </div>
                </setting>
            </block>
        </field>
    </record>
</odoo>

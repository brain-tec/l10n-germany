<odoo>
    <record id="l10n_de_dtfv_export_view_form" model="ir.ui.view">
        <field name="model">datev_export_dtvf.export</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        type="object"
                        name="action_generate"
                        invisible="state != 'draft'"
                        class="btn-primary"
                        string="Generate"
                    />
                    <button
                        type="object"
                        name="action_draft"
                        invisible="state != 'done'"
                        class="btn-secondary"
                        string="Reset to draft"
                    />
                    <field name="state" widget="statusbar" />
                </header>
                <sheet>
                    <group name="data">
                        <field
                            name="fiscalyear_id"
                            required="state == 'draft'"
                            readonly="state != 'draft'"
                        />
                        <field
                            name="name"
                            required="state == 'draft'"
                            readonly="state != 'draft'"
                        />
                        <field name="fiscalyear_start" invisible="True" />
                        <field name="fiscalyear_end" invisible="True" />
                        <field
                            name="period_ids"
                            domain="[('date_start', '&gt;=', fiscalyear_start), ('date_end', '&lt;=', fiscalyear_end)]"
                            readonly="not fiscalyear_id or state != 'draft'"
                            required="state == 'draft'"
                        />
                        <field
                            name="journal_ids"
                            widget="many2many_tags"
                            readonly="state != 'draft'"
                        />
                    </group>
                    <group name="result" invisible="state != 'done'">
                        <field name="date_generated" />
                        <field name="file_name" invisible="True" />
                        <field name="file_data" filename="file_name" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="datev_export_dtvf_view_tree" model="ir.ui.view">
        <field name="model">datev_export_dtvf.export</field>
        <field name="arch" type="xml">
            <list>
                <field name="display_name" />
                <field name="fiscalyear_id" />
                <field name="state" />
                <field name="date_generated" />
            </list>
        </field>
    </record>

    <record id="action_datev_export_dtvf" model="ir.actions.act_window">
        <field name="res_model">datev_export_dtvf.export</field>
        <field name="name">DATEV DTVF Export</field>
    </record>

    <menuitem
        id="menu_datev_export_dtvf"
        parent="account.menu_finance_reports"
        sequence="110"
        action="action_datev_export_dtvf"
    />
</odoo>

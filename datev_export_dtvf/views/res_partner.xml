<odoo>
    <record id="view_res_partner_form" model="ir.ui.view">
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='accounting']/group" position="inside">
                <group
                    name="datev_export_dtvf"
                    string="DATEV identifiers"
                    invisible="not l10n_de_datev_export_show"
                >
                    <field name="l10n_de_datev_export_show" invisible="True" />
                    <field name="l10n_de_datev_export_identifier_customer" />
                    <button
                        type="object"
                        name="action_l10n_de_datev_export_identifier_customer"
                        class="btn btn-secondary"
                        string="Generate"
                        invisible="l10n_de_datev_export_identifier_customer"
                    />
                    <field name="l10n_de_datev_export_identifier_supplier" />
                    <button
                        type="object"
                        name="action_l10n_de_datev_export_identifier_supplier"
                        class="btn btn-secondary"
                        string="Generate"
                        invisible="l10n_de_datev_export_identifier_supplier"
                    />
                </group>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hr_expense_sheet_view_form_extended" model="ir.ui.view">
        <field name="name">view.hr.expense.form.extended</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']/.." position="before">
                <notebook invisible="not is_meal_allowance">
                    <page name="travel_info" string="Travel Information">
                        <group>
                            <group>
                                <field name="travel_end" invisible="1" />
                                <field
                                    name="travel_begin"
                                    widget="daterange"
                                    options="{'end_date_field': 'travel_end', 'always_range': '1'}"
                                    readonly="not is_editable"
                                />
                                <field name="customer_id" readonly="not is_editable" />
                                <field
                                    name="meal_allowance_rate_id"
                                    readonly="not is_editable"
                                />
                            </group>
                            <group>
                                <field name="number_of_days" />
                                <field name="number_of_travel_days" />
                            </group>
                        </group>
                    </page>
                    <page name="included_meals" string="Included Meals">
                        <field
                            nolabel='1'
                            name="meal_allowance_ids"
                            readonly="not is_editable"
                        >
                            <list editable="bottom" create="0" delete="0">
                                <field name="date" widget="date" />
                                <field name="day" />
                                <field name="breakfast_included" />
                                <field name="lunch_included" />
                                <field name="dinner_included" />
                                <field name="currency_id" invisible="True" />
                                <field name="expense_for_day" widget='monetary' />
                            </list>
                        </field>
                    </page>
                </notebook>
            </xpath>
            <xpath expr="//header/button[@name='action_view_sheet']" position="after">
                <button
                    invisible="not is_meal_allowance"
                    name="action_print"
                    type="object"
                    class="btn-primary"
                    barcode_trigger="print"
                    string="Print Expenses"
                />
            </xpath>
            <xpath
                expr="//field[@name='total_amount' and hasclass('oe_inline')]"
                position="attributes"
            >
                <attribute name="readonly" add="is_meal_allowance" separator="or" />
            </xpath>
            <xpath expr="//field[@name='total_amount_currency']" position="attributes">
                <attribute name="readonly" add="is_meal_allowance" separator="or" />
            </xpath>
            <xpath expr="//div/field[@name='currency_id']" position="attributes">
                <attribute name="readonly" add="is_meal_allowance" separator="or" />
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="action_report_hr_expense_meal_allowance" model="ir.actions.report">
        <field name="name">Expenses Report</field>
        <field name="model">hr.expense</field>
        <field name="report_type">qweb-pdf</field>
        <field
            name="report_name"
        >hr_expense_meal_allowance.report_expense_meal_allowance</field>
        <field
            name="report_file"
        >hr_expense_meal_allowance.report_expense_meal_allowance</field>
        <field name="binding_model_id" ref="model_hr_expense" />
        <field name="binding_type">report</field>
        <field
            name="attachment"
        >((object.name or 'Expenses').replace('/','_')+'.pdf')</field>
    </record>
</odoo>
